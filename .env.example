# NORDLUXE Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nordluxe_db
DB_USER=nordluxe_user
DB_PASS=your_secure_database_password

# Application Settings
NODE_ENV=production
PORT=8080
JWT_SECRET=your_super_secure_jwt_secret_key_here
SESSION_SECRET=your_session_secret_key

# Payment Processing (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Payment Processing (Flutterwave)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_public_key_here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_secret_key_here
FLUTTERWAVE_SECRET_HASH=your_flutterwave_webhook_secret_hash

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=NORDLUXE <noreply@nordluxe.io>

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Firebase Admin (for server-side password reset links)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Apple Sign In
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=path/to/AuthKey.p8

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Admin Email
ADMIN_EMAIL=admin@nordluxe.com

# Newsletter — secret key to protect the /api/newsletter/send endpoint
# Set this to any long random string you keep private
NEWSLETTER_ADMIN_KEY=replace_with_a_long_random_secret_string

# File Upload (AWS S3, Cloudinary, etc.)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=nordluxe-uploads

# Analytics & Monitoring
GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# Social Media API Keys (if needed)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
TIKTOK_ACCESS_TOKEN=your_tiktok_token

# Security
CSP_NONCE_SECRET=your_csp_nonce_secret
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# External APIs
OPENAI_API_KEY=your_openai_key_if_needed
WEATHER_API_KEY=your_weather_api_key_if_needed

# Admin Configuration
ADMIN_EMAIL=admin@nordluxe.com
ADMIN_PASSWORD=change_this_immediately

# Backup Settings
BACKUP_FREQUENCY=daily
BACKUP_RETENTION=30

# CDN Configuration
CDN_URL=https://cdn.nordluxe.com
CDN_API_KEY=your_cdn_api_key